# Скопируйте в .env и заполните значениями

# Postgres (Railway: Settings → Database → Connection URL)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Redis (Upstash: Console → Connect → ioredis → rediss://... )
REDIS_URL=rediss://default:password@hostname:port

# Claude API (https://console.anthropic.com → API Keys)
ANTHROPIC_API_KEY=sk-ant-...

# Порт сервера (опционально, default: 3000)
PORT=3000

# Origin фронтенда для CORS (опционально, default: http://localhost:5173)
CORS_ORIGIN=http://localhost:5173

# Telegram-пуш админу при аномалии на гостевом аккаунте (опционально — без них тихо не отправляется)
TELEGRAM_ALERT_BOT_TOKEN=
TELEGRAM_ALERT_CHAT_ID=

# ЭКСПЕРИМЕНТ (2026-07-11): ИИ решает, куда контратакует ВСУ, вместо детерминированной формулы —
# см. ai/ukraine-counterattack-ai.js. По умолчанию выключено (обычное поведение).
UKRAINE_AI_COUNTERATTACK_ENABLED=false
